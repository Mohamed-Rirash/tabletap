# Copy to .env and fill in real values. .env is gitignored.
#
# Supabase Storage is S3-compatible — find these under your Supabase
# project: Storage → Settings → S3 Connection.
#
# If these are left unset, dev/test fall back to local disk storage
# (priv/static/uploads) so the app runs without a Supabase project.

SUPABASE_S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_BUCKET=menu-photos
