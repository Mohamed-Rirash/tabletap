<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title
      default="TableTap — QR Ordering for Cafés & Restaurants"
      suffix=" · TableTap"
      phx-no-format
    >{assigns[:page_title]}</.live_title>
    <meta
      name="description"
      content="Scan, order, pay, and track — live. TableTap runs the whole floor: menu, kitchen, waiters, inventory, and mobile-money or card payments, in one system."
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <%!-- Only the two installable surfaces (customer QR flow, waiter queue)
    assign `@pwa_manifest` — see TabletapWeb.PwaHooks — build-plan.md
    Feature 20 "PWA manifests per surface (customer/waiter)". --%>
    <%= if assigns[:pwa_manifest] do %>
      <link rel="manifest" href={"/manifest-#{@pwa_manifest}.webmanifest"} />
      <meta name="apple-mobile-web-app-capable" content="yes" />
      <meta name="apple-mobile-web-app-title" content="TableTap" />
    <% end %>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const systemTheme = () => matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";

        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.setAttribute("data-theme", systemTheme());
            document.documentElement.setAttribute("data-theme-source", "system");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
            document.documentElement.setAttribute("data-theme-source", "user");
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));

        matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
          if (document.documentElement.getAttribute("data-theme-source") === "system") {
            document.documentElement.setAttribute("data-theme", systemTheme());
          }
        });
      })();
    </script>
  </head>
  <body>
    <%!-- Offline/reconnect shell (build-plan.md Feature 20) — plain JS in
    app.js drives this (`pwa.js`'s `initOfflineBanner/1`), not a phx-hook:
    this div sits in the root layout's own static shell, outside any
    LiveView's managed DOM subtree, so a phx-hook here would never
    initialize. --%>
    <div
      id="offline-banner"
      class="hidden fixed inset-x-0 top-0 z-50 bg-warning text-warning-content text-center text-sm py-1.5"
    >
      You're offline — reconnecting…
    </div>
    <%= if assigns[:pwa_manifest] do %>
      <button
        id="pwa-install-button"
        type="button"
        class="hidden fixed bottom-4 right-4 z-50 btn btn-primary btn-sm shadow-lg"
      >
        Install app
      </button>
    <% end %>
    <%!-- Slim, sitewide utility bar: account access from anywhere (settings/
    log-out) that isn't otherwise reachable. The marketing home page carries
    its own dark nav with the same links (it forces a dark look regardless
    of theme preference, like KDS does — see app.css ".mk"), so this stays
    suppressed there via @hide_utility_bar to avoid two competing bars. --%>
    <%= unless assigns[:hide_utility_bar] do %>
      <div
        id="utility-bar"
        class="w-full border-b border-base-300/60 bg-base-100/80 backdrop-blur"
      >
        <ul class="menu menu-horizontal w-full max-w-6xl mx-auto flex items-center gap-1 px-4 sm:px-6 lg:px-8 py-1 justify-end text-sm">
          <%= if @current_scope && @current_scope.user do %>
            <li class="text-base-content/60">{@current_scope.user.email}</li>
            <li><.link href={~p"/users/settings"} class="link link-hover">Settings</.link></li>
            <li>
              <.link href={~p"/users/log-out"} method="delete" class="link link-hover">
                Log out
              </.link>
            </li>
          <% else %>
            <li><.link href={~p"/users/log-in"} class="link link-hover">Log in</.link></li>
            <li>
              <.link href={~p"/users/register"} class="link link-hover font-semibold">
                Start free trial
              </.link>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
    {@inner_content}
  </body>
</html>
