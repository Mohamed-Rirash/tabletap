<div class="min-h-screen grid place-items-center px-4">
  <div class="max-w-sm w-full text-center space-y-3">
    <span class="grid h-12 w-12 mx-auto place-items-center rounded-full bg-base-200">
      <.icon name="hero-clock" class="size-6 opacity-60" />
    </span>
    <h1 class="text-lg font-semibold">{gettext("Too many scans, too fast")}</h1>
    <p class="text-sm text-base-content/60">
      {gettext("Please wait a moment and try scanning again.")}
    </p>
  </div>
</div>
